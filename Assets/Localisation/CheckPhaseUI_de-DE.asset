      m_Items: []
  - m_Id: 137160581120
    m_Localized: Daten senden
    m_Metadata:
      m_Items: []
  - m_Id: 181397905408
    m_Localized: Ton abspielen
    m_Metadata:
      m_Items: []
  - m_Id: 232744574976
    m_Localized: "-Klicke auf Ton abspielen\n\n-Falls du dann einen Ton h\xF6rst,
      dr\xFCckst du auf \"Ich habe den Ton geh\xF6rt\"\n\n-Falls du nichts h\xF6rst
      dr\xFCcke auf \"Ich habe den Ton nicht geh\xF6rt\" \n\n-<color=green>Wiederhole
      das 6 mal</color>"
    m_Metadata:
      m_Items: []
  - m_Id: 250570366976
    m_Localized: "-Bitte f\xFClle noch den Fragebogen zum Spiel aus.\n\n-Klicke auf
      den Fragebogen, den du ausf\xFCllen m\xF6chtest\n"
    m_Metadata:
      m_Items: []
  - m_Id: 1324244326178816
    m_Localized: -Wenn du fertig bist klicke auf "Daten senden" (Mit dem Klick auf
      "Daten senden" akzeptierst du die anonyme Speicherung deiner Spielmetriken)
    m_Metadata:
      m_Items: []
