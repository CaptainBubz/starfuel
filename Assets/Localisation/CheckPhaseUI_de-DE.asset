  - m_Id: 47536693248
    m_Localized: "Ja - ich habe den Ton geh\xF6rt"
    m_Metadata:
      m_Items: []
  - m_Id: 98484903936
    m_Localized: "Nein - ich habe keinen Ton geh\xF6rt"
    m_Metadata:
      m_Items: []
  - m_Id: 137160581120
    m_Localized: Daten senden
    m_Metadata:
      m_Items: []
  - m_Id: 181397905408
    m_Localized: Ton abspielen
    m_Metadata:
      m_Items: []
  - m_Id: 232744574976
    m_Localized: "-Klicke auf Ton abspielen\n-Falls du dann einen Ton h\xF6rst dr\xFCckst
      du auf \"ich habe den Ton geh\xF6rt\"\n-Falls du nichts h\xF6rst dr\xFCcke
      auf \"ich habe den Ton nicht geh\xF6rt. \n-Wenn du fertig bist klicke auf \"Daten
      senden\" (Mit dem Klick auf Daten \xFCbertragen akzeptierst du die anonyme
      Speicherung deiner Spielmetriken)"
    m_Metadata:
      m_Items: []
  - m_Id: 250570366976
    m_Localized: "Bitte f\xFClle noch den Fragebogen zum Spiel aus.\n\nKlicke auf
      den Fragebogen, den du ausf\xFCllen m\xF6chtest\n"
    m_Metadata:
      m_Items: []
